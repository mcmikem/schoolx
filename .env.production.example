# ============================================
# PRODUCTION ENVIRONMENT
# Copy this to .env.production before deploying
# ============================================

# Supabase (Production URL - update after rotating keys)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_NEW_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_NEW_SERVICE_ROLE_KEY

# PayPal (Live - rotate these!)
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=YOUR_NEW_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_NEW_CLIENT_SECRET

# Stripe
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# SMS APIs
AFRICAS_TALKING_API_KEY=YOUR_AT_API_KEY
SMS_API_KEY=YOUR_SMS_API_KEY

# Email
RESEND_API_KEY=re_YOUR_RESEND_KEY
EMAIL_FROM=noreply@yourdomain.com

# Security
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://yourdomain.com
CRON_SECRET=YOUR_CRON_SECRET

# Redis for rate limiting (production)
REDIS_URL=redis://username:password@host:port