# ============================================
# PRODUCTION ENVIRONMENT
# Copy this to .env.production before deploying
# ============================================

# Supabase (Production URL - update after rotating keys)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_NEW_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_NEW_SERVICE_ROLE_KEY

# PayPal (Live - rotate these!)
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=YOUR_NEW_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_NEW_CLIENT_SECRET
PAYPAL_WEBHOOK_ID=YOUR_PAYPAL_WEBHOOK_ID

# Stripe
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
STRIPE_PRICE_STARTER=price_live_starter
STRIPE_PRICE_GROWTH=price_live_growth
STRIPE_PRICE_ENTERPRISE=price_live_enterprise
STRIPE_PRICE_LIFETIME=price_live_lifetime

# SMS APIs
AFRICAS_TALKING_API_KEY=YOUR_AT_API_KEY
AFRICAS_TALKING_USERNAME=YOUR_AT_USERNAME
SMS_API_KEY=YOUR_SMS_API_KEY
SMS_USERNAME=YOUR_SMS_USERNAME

# Email
RESEND_API_KEY=re_YOUR_RESEND_KEY
EMAIL_FROM=noreply@yourdomain.com

# Mobile money / AI imports
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-YOUR_PUBLIC_KEY
FLUTTERWAVE_SECRET_KEY=FLWSECK-YOUR_SECRET_KEY
FLUTTERWAVE_WEBHOOK_SECRET=YOUR_FLUTTERWAVE_WEBHOOK_SECRET
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Security
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://yourdomain.com
CRON_SECRET=YOUR_CRON_SECRET
# Keep dev/test routes disabled in production. Never set these to true on live deployments.
ENABLE_DEV_TEST_ROUTES=false
NEXT_PUBLIC_ENABLE_DEV_TEST_ROUTES=false

# Redis for rate limiting (production)
REDIS_URL=redis://username:password@host:port

# Optional: keep unset in production unless you explicitly want demo login support
# DEMO_ADMIN_PASSWORD=
