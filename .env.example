# ============================================
# OMUTO SCHOOL MANAGEMENT SYSTEM
# Environment Variables - Payment Integration
# ============================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Africa's Talking SMS
AFRICAS_TALKING_API_KEY=your-api-key
AFRICAS_TALKING_USERNAME=your-username

# Optional SMS gateway used by automation routes
SMS_API_KEY=your-sms-api-key
SMS_USERNAME=your-sms-username

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Price IDs (Create these in your Stripe Dashboard)
STRIPE_PRICE_STARTER=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_GROWTH=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_LIFETIME=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PayPal Configuration
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYPAL_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYPAL_BUSINESS_EMAIL=info@omuto.org
PAYPAL_WEBHOOK_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Flutterwave Configuration (for Mobile Money - Uganda)
# Flutterwave supports MTN Uganda and Airtel Money Uganda
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mobile Money Configuration
MTN_MOMO_ENABLED=true
AIRTEL_MONEY_ENABLED=true
MOBILE_MONEY_CALLBACK_URL=https://your-domain.com/api/payment/webhook/mobile-money

# Email Configuration (for receipts - using Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Omuto <payments@omuto.org>

# AI-assisted import parsing
GEMINI_API_KEY=your-gemini-api-key

# Demo/dev routes (never enable in production)
ENABLE_DEV_TEST_ROUTES=true
NEXT_PUBLIC_ENABLE_DEV_TEST_ROUTES=true

# Cron Job Security (generate a random string: openssl rand -hex 32)
CRON_SECRET=your-cron-secret-key

# Rate limiting / shared cache (recommended for multi-instance deployments)
REDIS_URL=redis://username:password@host:port

# Optional demo login override for non-production environments
DEMO_ADMIN_PASSWORD=skoolmate_demo_2024

# Subscription Settings
SUBSCRIPTION_TRIAL_DAYS=30
TERMS_PER_YEAR=3
